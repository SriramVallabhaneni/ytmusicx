{
  "manifest_version": 3,
  "name": "YouTube Music Markers",
  "version": "0.1.0",
  "description": "Add marker-aware skipping to YouTube Music.",
  "permissions": [],
  "host_permissions": ["https://music.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}